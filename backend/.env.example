# Local API (no Docker): use localhost.
# Docker Compose (api/worker/beat): Postgres on host — use host.docker.internal (Compose sets this via DATABASE_URL default).
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@localhost:5432/jarvis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
SECRET_KEY=change-me-use-openssl-rand-hex-32
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FIREBASE_CREDENTIALS_PATH=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
